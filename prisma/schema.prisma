generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String              @id @default(cuid())
  fullName             String
  email                String              @unique
  passwordHash         String
  role                 Role                @default(OWNER)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  staffBookings        Booking[]           @relation("StaffBookings")
  ownedSalons          Salon[]
  staffAvailability    StaffAvailability[]
  staffWaitlistEntries WaitlistEntry[]     @relation("StaffWaitlistEntries")
  staffWalkIns         WalkIn[]            @relation("StaffWalkIns")
}

model Salon {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branches  Branch[]
  owner     User     @relation(fields: [ownerId], references: [id])
}

model Branch {
  id                String              @id @default(cuid())
  salonId           String
  name              String
  city              String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  bookings          Booking[]
  salon             Salon               @relation(fields: [salonId], references: [id])
  Resource          Resource[]
  staffAvailability StaffAvailability[]
  waitlistEntries   WaitlistEntry[]
  walkIns           WalkIn[]
}

model Lead {
  id           String     @id @default(cuid())
  fullName     String
  businessName String?
  email        String?
  phone        String?
  city         String?
  message      String?
  formType     String
  sourcePage   String
  status       LeadStatus @default(NEW)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Client {
  id                    String          @id @default(cuid())
  fullName              String
  phone                 String?
  email                 String?
  gender                String?
  dateOfBirth           DateTime?
  address               String?
  city                  String?
  notes                 String?
  loyaltyPoints         Int             @default(0)
  walletBalance         Float           @default(0)
  totalVisits           Int             @default(0)
  totalSpend            Float           @default(0)
  lastVisitAt           DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  bookings              Booking[]
  clientWaitlistEntries WaitlistEntry[]
  walkIns               WalkIn[]
}

model Booking {
  id          String           @id @default(cuid())
  branchId    String
  clientId    String
  staffId     String?
  title       String
  notes       String?
  status      BookingStatus    @default(PENDING)
  startTime   DateTime
  endTime     DateTime
  totalAmount Float            @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  branch      Branch           @relation(fields: [branchId], references: [id])
  client      Client           @relation(fields: [clientId], references: [id])
  staff       User?            @relation("StaffBookings", fields: [staffId], references: [id])
  services    BookingService[]
  walkIns     WalkIn[]

  @@index([branchId])
  @@index([clientId])
  @@index([staffId])
  @@index([startTime])
  @@index([status])
}

model BookingService {
  id          String   @id @default(cuid())
  bookingId   String
  name        String
  durationMin Int
  price       Float    @default(0)
  createdAt   DateTime @default(now())
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model StaffAvailability {
  id        String   @id @default(cuid())
  branchId  String
  staffId   String
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branch    Branch   @relation(fields: [branchId], references: [id])
  staff     User     @relation(fields: [staffId], references: [id])

  @@unique([branchId, staffId, dayOfWeek, startTime, endTime])
  @@index([branchId])
  @@index([staffId])
}

model WaitlistEntry {
  id             String         @id @default(cuid())
  branchId       String
  clientId       String?
  staffId        String?
  requestedDate  DateTime
  preferredStart DateTime?
  preferredEnd   DateTime?
  serviceName    String?
  notes          String?
  status         WaitlistStatus @default(WAITING)
  priority       Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  branch         Branch         @relation(fields: [branchId], references: [id])
  client         Client?        @relation(fields: [clientId], references: [id])
  staff          User?          @relation("StaffWaitlistEntries", fields: [staffId], references: [id])

  @@index([branchId])
  @@index([clientId])
  @@index([staffId])
  @@index([requestedDate])
  @@index([status])
  @@index([priority])
}

model Resource {
  id          String       @id @default(cuid())
  branchId    String
  name        String
  type        ResourceType
  description String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  branch      Branch       @relation(fields: [branchId], references: [id])

  @@index([branchId])
  @@index([type])
  @@index([isActive])
}

model WalkIn {
  id                   String       @id @default(cuid())
  branchId             String
  clientId             String?
  staffId              String?
  bookingId            String?
  customerName         String?
  phone                String?
  serviceName          String?
  notes                String?
  status               WalkInStatus @default(WAITING)
  queueNumber          Int
  arrivalTime          DateTime     @default(now())
  estimatedWaitMinutes Int          @default(0)
  calledAt             DateTime?
  startedAt            DateTime?
  completedAt          DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  booking              Booking?     @relation(fields: [bookingId], references: [id])
  branch               Branch       @relation(fields: [branchId], references: [id])
  client               Client?      @relation(fields: [clientId], references: [id])
  staff                User?        @relation("StaffWalkIns", fields: [staffId], references: [id])

  @@index([branchId])
  @@index([clientId])
  @@index([staffId])
  @@index([bookingId])
  @@index([status])
  @@index([arrivalTime])
  @@index([queueNumber])
}

model Notification {
  id        String               @id @default(cuid())
  branchId  String?
  userId    String?
  type      NotificationType
  priority  NotificationPriority @default(MEDIUM)
  title     String
  message   String
  link      String?
  read      Boolean              @default(false)
  archived  Boolean              @default(false)
  readAt    DateTime?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([branchId])
  @@index([userId])
  @@index([type])
  @@index([read])
  @@index([archived])
  @@index([createdAt])
}

enum NotificationType {
  BOOKING
  WAITLIST
  WALK_IN
  AI_ALERT
  STAFF_ALERT
  SYSTEM_ALERT
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WaitlistStatus {
  WAITING
  CONTACTED
  BOOKED
  CANCELLED
  EXPIRED
}

enum ResourceType {
  CHAIR
  ROOM
  EQUIPMENT
  STATION
}

enum Role {
  SUPER_ADMIN
  OWNER
  MANAGER
  RECEPTIONIST
  STYLIST
  THERAPIST
  CASHIER
  MARKETING_EXECUTIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  DEMO_SCHEDULED
  CONVERTED
  LOST
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum WalkInStatus {
  WAITING
  CALLED
  IN_SERVICE
  COMPLETED
  CANCELLED
  NO_SHOW
  CONVERTED
}
